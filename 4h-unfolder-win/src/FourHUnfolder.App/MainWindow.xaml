<Window x:Class="FourHUnfolder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:ctrl="clr-namespace:FourHUnfolder.App.Controls"
        Title="4H-Unfolder v0.1.0.A — Paper Model Unfolder"
        Icon="Assets/app.ico"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource AppBg}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Compact icon-only style for main toolbar — Segoe Fluent Icons, Windows 11 Fluent Design -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Margin"      Value="2,1"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Setter Property="FontSize"    Value="16"/>
            <Setter Property="FontFamily"  Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="MinWidth"  Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl"       Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl"       Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="A" Modifiers="Ctrl"       Command="{Binding SelectAllCommand}"/>
        <KeyBinding Key="F3"                        Command="{Binding FitPageCommand}"/>
        <KeyBinding Key="F4"                        Command="{Binding ZoomToSelectedCommand}"/>
        <KeyBinding Key="G" Modifiers="Ctrl"        Command="{Binding GroupCommand}"/>
        <KeyBinding Key="G" Modifiers="Ctrl+Shift"  Command="{Binding UngroupCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl+Shift"  Command="{Binding OpenFindCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- 0: viewports    -->
            <RowDefinition Height="Auto"/>  <!-- 1: status bar   -->
            <RowDefinition Height="Auto"/>  <!-- 2: main toolbar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — viewports ════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LeftColumnWidth}"/>
                <ColumnDefinition Width="{Binding SplitterColumnWidth}"/>
                <ColumnDefinition Width="{Binding RightColumnWidth}"/>
            </Grid.ColumnDefinitions>

            <!-- 3-D Model Viewport -->
            <Border Grid.Column="0"
                    BorderBrush="{Binding ViewportBorderBrush}"
                    BorderThickness="2" CornerRadius="4" Margin="4,4,2,4">
                <Grid>
                    <helix:HelixViewport3D x:Name="Viewport3D"
                                          Background="{Binding Viewport3DBackground}"
                                          ShowCoordinateSystem="{Binding Show3DCoordinateSystem}"
                                          ShowViewCube="{Binding Show3DViewCube}"
                                          MouseDown="Viewport3D_MouseDown"
                                          MouseMove="Viewport3D_MouseMove"
                                          PreviewMouseLeftButtonDown="Viewport3D_PreviewLMBDown"
                                          PreviewMouseRightButtonDown="Viewport3D_RMBDown"
                                          PreviewMouseRightButtonUp="Viewport3D_RMBUp">
                        <helix:HelixViewport3D.Camera>
                            <PerspectiveCamera x:Name="MainCamera3D"
                                               Position="3,3,3"
                                               LookDirection="-1,-1,-1"
                                               UpDirection="0,1,0"
                                               FieldOfView="45"
                                               NearPlaneDistance="0.01"
                                               FarPlaneDistance="5000"/>
                        </helix:HelixViewport3D.Camera>
                        <helix:DefaultLights/>
                        <!-- Primary mesh -->
                        <ModelVisual3D Content="{Binding MeshModel}"/>
                        <!-- Selection highlight overlay (semi-transparent, z-offset) -->
                        <ModelVisual3D Content="{Binding SelectionOverlayModel}"/>
                        <!-- Feature B: 3D edge hover highlight -->
                        <ModelVisual3D Content="{Binding EdgeHighlightModel}"/>
                    </helix:HelixViewport3D>

                    <TextBlock Text="3D Model"
                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                               Margin="8,6" VerticalAlignment="Top" HorizontalAlignment="Left"
                               IsHitTestVisible="False"/>

                    <!-- Preview badge -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6"
                            Background="#cc7a00" CornerRadius="4" Padding="10,3"
                            Visibility="{Binding PreviewBadgeVisible}">
                        <TextBlock Text="{Binding PreviewLabelText}"
                                   Foreground="White" FontWeight="Bold" FontSize="12"
                                   IsHitTestVisible="False"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="{Binding SplitterColumnWidth}"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBg}"
                          Visibility="{Binding RightPanelVisible}"/>

            <!-- 2-D Pattern Canvas -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource BorderNormal}" BorderThickness="1"
                    CornerRadius="4" Margin="2,4,4,4"
                    Visibility="{Binding RightPanelVisible}">
                <Grid>
                    <ctrl:PatternCanvasControl
                        x:Name="PatternCanvas"
                        DataContext="{Binding}"/>

                    <TextBlock Text="2D Pattern Layout"
                               Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="8,6"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Row 1 — status bar + Find bar overlay ═════════════════════ -->
        <!-- Find bar: shown on Ctrl+Shift+F, hidden by default -->
        <Border x:Name="FindBar" Grid.Row="1" Visibility="Collapsed"
                Background="{DynamicResource ToolbarBg}" Padding="8,4"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                CornerRadius="4" Margin="0,2,8,2" Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Find part #:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,6,0"/>
                <TextBox x:Name="FindTextBox" Width="100" VerticalAlignment="Center"
                         KeyDown="FindTextBox_KeyDown"/>
                <Button Content="&#xE711;" Click="FindClose_Click" Margin="4,0,0,0"
                        Style="{StaticResource IconBtn}" FontSize="13" Padding="4,2"/>
            </StackPanel>
        </Border>
        <StatusBar Grid.Row="1" Background="{DynamicResource StatusBarBg}" Padding="4,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource StatusTextFg}" FontFamily="Consolas" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusZoomText}"
                           Foreground="{DynamicResource StatusTextFg}" FontFamily="Consolas" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Right-click edge → Join/Split  ·  LMB=rotate 3D  ·  Scroll=zoom 2D  ·  Shift/Ctrl+click=multi-select"
                           Foreground="{DynamicResource TextHint}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Row 2 — main toolbar (Segoe Fluent Icons) ═══════════════════ -->
        <!--
             Icon map (Segoe Fluent Icons / Segoe MDL2 Assets Unicode):
             E838=Folder  E9B4=Ruler  E74E=Save  E8A5=Documents  E792=SaveLocal
             E8E0=Import  E713=Settings  E7A7=Undo  E7A6=Redo  E2B1=Color
             E8B2=Video  E74B=Cut  E9A9=Resize  E7B8=Flip  E8A4=ZoomFit
             E71E=Zoom  E8B3=SelectAll  F168=Group  F169=Ungroup  E72C=Refresh
             E8CC=SnipRetract  E8C8=Copy  E8D5=ViewAll  E8C4=Tiles  E81C=Ruler2
        -->
        <Border Grid.Row="2" Background="{DynamicResource ToolbarBg}" Padding="4,3">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Cluster 1: File / System -->
                <Button Style="{StaticResource IconBtn}" Content="&#xE838;"
                        Command="{Binding LoadMeshCommand}"
                        ToolTip="Load Mesh (.obj, .pdo, .fbx, .stl, …)"/>
                <Separator/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE9B4;"
                        Command="{Binding UnfoldCommand}" IsEnabled="{Binding CanUnfold}"
                        ToolTip="Unfold — open setup dialog"/>
                <Separator/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE74E;"
                        Command="{Binding ExportSvgCommand}" IsEnabled="{Binding CanExport}"
                        ToolTip="Export SVG pattern"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8A5;"
                        Command="{Binding ExportPdfCommand}" IsEnabled="{Binding CanExport}"
                        ToolTip="Export PDF pattern"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xEB9F;"
                        Command="{Binding ExportPngCommand}" IsEnabled="{Binding CanExport}"
                        ToolTip="Export PNG pattern (one image per page — for cutting machines)"/>
                <Separator/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE792;"
                        Command="{Binding SaveProjectCommand}" IsEnabled="{Binding CanExport}"
                        ToolTip="Save project (.pmc)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8E0;"
                        Command="{Binding LoadProjectCommand}"
                        ToolTip="Load project (.pmc)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE713;"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="Settings (3D / 2D / Print / General)"/>
                <Separator/>
                <!-- Cluster 2: Undo / Redo -->
                <Button Style="{StaticResource IconBtn}" Content="&#xE7A7;"
                        Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}"
                        ToolTip="Undo  (Ctrl+Z)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE7A6;"
                        Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}"
                        ToolTip="Redo  (Ctrl+Y)"/>
                <Separator/>
                <!-- Cluster 3: View / Tools -->
                <Button Style="{StaticResource IconBtn}" Content="&#xE2B1;"
                        Click="TextureButton_Click"
                        Visibility="{Binding TexturePanelVisible}"
                        ToolTip="Texture manager"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8B2;"
                        Command="{Binding OpenAssemblyAnimationCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Assembly animation — step-by-step fold guide"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE74B;"
                        Click="EditFlapsButton_Click"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Edit Flaps — control glue tab placement per edge"/>
                <Separator/>
                <!-- Cluster 4: 2D Layout tools -->
                <Button Style="{StaticResource IconBtn}" Content="&#xE9A9;"
                        Command="{Binding OpenScaleDialogCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Rescale model (change physical output size)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE7B8;"
                        Command="{Binding ToggleMirrorInversionCommand}"
                        IsEnabled="{Binding CanUnfold}"
                        ToolTip="Mirror Inversion — flip model along X axis (both 3D and 2D)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8A4;"
                        Command="{Binding FitPageCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Fit Page to Window  (F3)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE71E;"
                        Command="{Binding ZoomToSelectedCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Zoom to Selected pieces  (F4)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8B3;"
                        Command="{Binding SelectAllCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Select All pieces  (Ctrl+A)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xF168;"
                        Command="{Binding GroupCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Group selected pieces  (Ctrl+G)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xF169;"
                        Command="{Binding UngroupCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Ungroup selected pieces  (Ctrl+Shift+G)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE72C;"
                        Command="{Binding UndoUnfoldCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Undo Unfold — clear all edge/flap overrides and reset layout"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8CC;"
                        Command="{Binding ResetCutlineEdgesCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Reset all cut edges → fold (Undo-able)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8C8;"
                        Click="CopyToClipboard_Click"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Copy 2D layout to clipboard (bitmap)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE8D5;"
                        Command="{Binding ToggleShow2DOnlyCommand}"
                        IsEnabled="{Binding CanExport}"
                        ToolTip="Show 2D Layout Only (hide 3D viewport)"/>
                <Separator/>
                <!-- Cluster 5: Pepakura model tools -->
                <Button Style="{StaticResource IconBtn}" Content="&#xE8C4;"
                        Command="{Binding SeparateAllFacesCommand}"
                        IsEnabled="{Binding CanUnfold}"
                        ToolTip="Separate All Faces — set every edge to cut (each face = own piece)"/>
                <Button Style="{StaticResource IconBtn}" Content="&#xE81C;"
                        Command="{Binding ToggleShowDimensionLinesCommand}"
                        IsEnabled="{Binding CanUnfold}"
                        ToolTip="Show Dimension Lines — overlay W/H/D labels in 3D viewport"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
