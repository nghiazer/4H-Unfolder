<Window x:Class="FourHUnfolder.App.Dialogs.EditFlapsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FourHUnfolder.App.ViewModels"
        Title="Edit Flaps"
        Width="340" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="{DynamicResource CheckBoxFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground"        Value="{DynamicResource CheckBoxFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Height"      Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"     Value="3,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Height"      Value="24"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource BtnOkBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource BtnOkFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BtnOkBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,3"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource BtnCancelBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource BtnOkFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BtnCancelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,3"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── TabControl ─────────────────────────────────────────────────── -->
        <TabControl Grid.Row="0"
                    SelectedIndex="{Binding ActiveTabIndex}"
                    Background="{DynamicResource DialogBg}"
                    BorderBrush="{DynamicResource InputBorder}">

            <!-- ── Tab 0: Shape (S) ──────────────────────────────────────── -->
            <TabItem Header="Shape (S)">
                <StackPanel Margin="8,10,8,6">

                    <!-- Set Height row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox IsChecked="{Binding SetHeight}" Content="Set Height"
                                  MinWidth="90"/>
                        <TextBlock Text="H =" Margin="8,0,4,0"/>
                        <TextBox Text="{Binding HeightMm, UpdateSourceTrigger=LostFocus,
                                        StringFormat={}{0:F1}}"
                                 Width="52"
                                 IsEnabled="{Binding SetHeight}"/>
                        <TextBlock Text=" mm" Margin="3,0,0,0"/>
                    </StackPanel>

                    <!-- Set Angle checkbox -->
                    <CheckBox IsChecked="{Binding SetAngle}" Content="Set Angle"
                              Margin="0,0,0,4"/>

                    <!-- Auto/Manual radios -->
                    <StackPanel Orientation="Horizontal" Margin="18,0,0,4">
                        <RadioButton Content="Auto"
                                     IsChecked="{Binding AngleAuto}"
                                     IsEnabled="{Binding SetAngle}"
                                     GroupName="AngleMode"/>
                        <RadioButton Content="Manual" Margin="14,0,0,0"
                                     IsEnabled="{Binding SetAngle}"
                                     GroupName="AngleMode"/>
                    </StackPanel>

                    <!-- L / R angle inputs -->
                    <StackPanel Orientation="Horizontal" Margin="18,0,0,8">
                        <TextBlock Text="L ="/>
                        <TextBox Text="{Binding LeftAngle, UpdateSourceTrigger=LostFocus,
                                        StringFormat={}{0:F0}}"
                                 Width="44" Margin="4,0,0,0"
                                 IsEnabled="{Binding SetAngle}"/>
                        <TextBlock Text="°" Margin="2,0,12,0"/>
                        <TextBlock Text="R ="/>
                        <TextBox Text="{Binding RightAngle, UpdateSourceTrigger=LostFocus,
                                        StringFormat={}{0:F0}}"
                                 Width="44" Margin="4,0,0,0"
                                 IsEnabled="{Binding SetAngle}"/>
                        <TextBlock Text="°" Margin="2,0,0,0"/>
                    </StackPanel>

                    <Separator Margin="0,4,0,8"
                               Background="{DynamicResource InputBorder}"/>

                    <TextBlock Text="Apply to individual edge by clicking on canvas, or:"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource FieldLabelFg}"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <Button Style="{StaticResource ActionBtn}"
                            Content="Apply to All"
                            HorizontalAlignment="Left"
                            Command="{Binding ApplyShapeToAllCommand}"/>
                </StackPanel>
            </TabItem>

            <!-- ── Tab 1: Position (Q) ────────────────────────────────────── -->
            <TabItem Header="Position (Q)">
                <StackPanel Margin="8,10,8,6">

                    <TextBlock Text="Operation for Selected Edges"
                               FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <TextBlock Text="Inner Edge (with a partner):"
                               Foreground="{DynamicResource FieldLabelFg}"
                               FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{x:Static vm:EditFlapsViewModel.InnerEdgeOptions}"
                              SelectedItem="{Binding SelectedInnerMode}"
                              DisplayMemberPath="Label"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Border Edge (without a partner):"
                               Foreground="{DynamicResource FieldLabelFg}"
                               FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{x:Static vm:EditFlapsViewModel.BorderEdgeOptions}"
                              SelectedItem="{Binding SelectedBorderMode}"
                              DisplayMemberPath="Label"
                              Margin="0,0,0,12"/>

                    <Button Style="{StaticResource ActionBtn}"
                            Content="Reset All to Default"
                            HorizontalAlignment="Left"
                            Command="{Binding ResetToDefaultCommand}"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- ── Footer ─────────────────────────────────────────────────────── -->
        <Button Grid.Row="1"
                Style="{StaticResource CloseBtn}"
                Content="Close"
                HorizontalAlignment="Right"
                Margin="0,8,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
