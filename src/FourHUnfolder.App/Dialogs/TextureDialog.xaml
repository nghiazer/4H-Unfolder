<Window x:Class="FourHUnfolder.App.Dialogs.TextureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Texture Manager" Width="520" Height="380"
        MinWidth="420" MinHeight="300"
        ResizeMode="CanResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e3c" Foreground="White">

    <Window.Resources>
        <!-- Checkerboard pattern for transparent-bg indicator -->
        <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#555566" Geometry="M0,0 H8 V8 H0 Z"/>
                    <GeometryDrawing Brush="#333344" Geometry="M0,0 H4 V4 H0 Z M4,4 H8 V8 H4 Z"/>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Left panel — material slot list ═══════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="#12122b" BorderBrush="#2a2a4a" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="MATERIALS" Foreground="#555577"
                           FontSize="9" FontWeight="Bold" Margin="10,10,0,6"/>
                <ListBox x:Name="MaterialList"
                         Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding MaterialTextureSlots}"
                         SelectionChanged="MaterialList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"     Value="8,6"/>
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor"      Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2a2a5a"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22224a"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <!-- Mini thumbnail -->
                                <Border Width="32" Height="32" Margin="0,0,8,0"
                                        BorderBrush="#444466" BorderThickness="1">
                                    <Grid>
                                        <Rectangle Fill="{StaticResource CheckerBrush}"/>
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="LowQuality"/>
                                    </Grid>
                                </Border>
                                <!-- Name + file -->
                                <StackPanel VerticalAlignment="Center" MaxWidth="130">
                                    <TextBlock Text="{Binding MaterialName}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ShortName}"
                                               Foreground="#8888aa" FontSize="10"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ Right panel — selected slot detail ═════════════════════════ -->
        <Grid Grid.Row="0" Grid.Column="1" Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock x:Name="SelectedMaterialLabel"
                           Text="Select a material slot"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock x:Name="SelectedFileLabel"
                           Text="" Foreground="#8888aa" FontSize="11"
                           TextTrimming="CharacterEllipsis" MaxWidth="260"/>
            </StackPanel>

            <!-- Large thumbnail -->
            <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="120" Height="120"
                    BorderBrush="#444466" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Rectangle Fill="{StaticResource CheckerBrush}"/>
                    <Image x:Name="LargeThumbnail" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="NoTextureLbl"
                               Text="No texture" Foreground="#666688" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="LoadBtn" Content="🎨  Load texture"
                        Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                        Background="#1a3a1a" Foreground="#90ff90" BorderBrush="#2a7a2a"
                        Click="LoadBtn_Click"/>
                <Button x:Name="RemoveBtn" Content="✖  Remove"
                        Padding="12,6" Cursor="Hand"
                        Background="#3a1a1a" Foreground="#ff9090" BorderBrush="#7a2a2a"
                        IsEnabled="False"
                        Click="RemoveBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Footer ════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#12122b" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="  Close  " Width="80" Height="28"
                        Background="#2a2a50" Foreground="White" BorderBrush="#4444aa"
                        Click="CloseBtn_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
