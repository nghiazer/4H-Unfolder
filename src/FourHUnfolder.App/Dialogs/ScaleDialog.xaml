<Window x:Class="FourHUnfolder.App.Dialogs.ScaleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rescale Model"
        Width="400" Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource FieldLabelFg}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource InputBorder}"/>
            <Setter Property="Padding"                  Value="4,0"/>
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Height"      Value="26"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"  Value="{DynamicResource GroupBoxFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GroupBoxBorder}"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
            <Setter Property="Padding"     Value="10,8"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <GroupBox DockPanel.Dock="Top" Header="Model Dimensions (Real World Scale)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                           x:Name="BBoxLabel"
                           Text="Bounding box: —"
                           Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>

                <Label  Grid.Row="2" Grid.Column="0" Content="Scale axis :"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          x:Name="AxisCombo" SelectedIndex="3" Margin="0,0,6,0">
                    <ComboBoxItem>Width  (X)</ComboBoxItem>
                    <ComboBoxItem>Height (Y)</ComboBoxItem>
                    <ComboBoxItem>Depth  (Z)</ComboBoxItem>
                    <ComboBoxItem>Longest axis</ComboBoxItem>
                </ComboBox>
                <TextBox  Grid.Row="2" Grid.Column="2"
                          x:Name="TargetSizeBox" Text="200" Margin="0,0,6,0"/>
                <ComboBox Grid.Row="2" Grid.Column="3"
                          x:Name="UnitCombo" SelectedIndex="0">
                    <ComboBoxItem>mm</ComboBoxItem>
                    <ComboBoxItem>cm</ComboBoxItem>
                    <ComboBoxItem>inch</ComboBoxItem>
                </ComboBox>
            </Grid>
        </GroupBox>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="OK"
                    Width="80" Height="34" Margin="0,0,10,0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Background="{DynamicResource BtnOkBg}"
                    Foreground="{DynamicResource BtnOkFg}"
                    BorderBrush="{DynamicResource BtnOkBorder}"
                    Click="OK_Click"/>
            <Button Content="Cancel"
                    Width="80" Height="34"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Background="{DynamicResource BtnCancelBg}"
                    Foreground="{DynamicResource BtnCancelFg}"
                    BorderBrush="{DynamicResource BtnCancelBorder}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
