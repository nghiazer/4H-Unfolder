{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "4H Unfolder",
  "version": "0.0.1-alpha",
  "identifier": "com.fourh.unfolder",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "devUrl":             "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist":       "../dist"
  },
  "app": {
    "windows": [
      {
        "title":          "4H Unfolder",
        "width":          1440,
        "height":         900,
        "minWidth":       960,
        "minHeight":      600,
        "resizable":      true,
        "fullscreen":     false,
        "decorations":    true,
        "transparent":    false,
        "center":         true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active":      true,
    "targets":     "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements":               null,
      "exceptionDomain":            null,
      "frameworks":                 [],
      "providerShortName":          null,
      "signingIdentity":            null,
      "minimumSystemVersion":       "13.0",
      "dmg": {}
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
